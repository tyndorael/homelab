# Diagrams stack environment variables — copy to .env and fill in your values

# Timezone
TZ=America/Santiago

# --- Excalidraw (whiteboard / freehand sketching) ---
# Host port (container listens on 80 internally)
EXCALIDRAW_PORT=8200

# --- draw.io (technical diagrams: flowcharts, UML, network maps) ---
# Host port (container listens on 8080 internally)
DRAWIO_PORT=8201
