# Remote-access stack environment variables — copy to .env and fill in values
#
# This stack provides Apache Guacamole (clientless RDP/VNC/SSH gateway in the
# browser). Cockpit is NOT here: it manages the host directly and is installed
# on the host with apt (see `make cockpit-install`), not as a container.

# Timezone
TZ=America/Santiago

# --- Apache Guacamole ---
# Web UI port exposed on the host (container listens on 8080 internally).
# Default 8088 to avoid clashing with other stacks.
GUAC_PORT=8088

# PostgreSQL connection — the DB stores users/connections/history.
GUAC_DB_NAME=guacamole_db
GUAC_DB_USER=guacamole
# Set a strong password. Generate one with:  openssl rand -base64 24
GUAC_DB_PASSWORD=

# PostgreSQL data dir (absolute or relative to this stack dir)
GUAC_DB_DATA=./data/postgres

# First login after `make remote-up`:  guacadmin / guacadmin
# Change this password immediately under Settings > Preferences.
