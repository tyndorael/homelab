# AI stack environment variables — copy to .env and fill in your values

# Timezone
TZ=America/Santiago

# UID/GID — run `id` to find your values. The container chowns its data dir to these.
PUID=1000
PGID=1000

# ComfyUI — port exposed on the host (change if 8188 is already taken)
COMFYUI_PORT=8188

# Volume path — ComfyUI base dir (models, output, input, custom_nodes).
# Populated on first run; large checkpoints live here, so point it at a fast disk.
COMFYUI_DATA=./data/comfyui
