# AI stack environment variables — copy to .env and fill in your values

# Timezone
TZ=America/Santiago

# UID/GID — run `id` to find your values. The container chowns its data dir to these.
PUID=1000
PGID=1000

# ComfyUI — port exposed on the host (change if 8188 is already taken)
COMFYUI_PORT=8188

# Volume path — ComfyUI base dir (models, output, input, custom_nodes).
# Populated on first run; large checkpoints live here, so point it at a fast disk.
COMFYUI_DATA=./data/comfyui

# --- Ollama (local LLM serving, GPU) ---
# Host port (API + OpenAI-compatible endpoint)
OLLAMA_PORT=11434
# Data dir — pulled models live here (large; point at a fast disk)
OLLAMA_DATA=./data/ollama

# --- Open WebUI (ChatGPT-style frontend for Ollama) ---
# Host port (container listens on 8080 internally)
OPENWEBUI_PORT=3080
# Data dir (SQLite DB, chats, settings)
OPENWEBUI_DATA=./data/open-webui

# --- faster-whisper (speech-to-text, GPU; Wyoming protocol on 10300) ---
# Host port
WHISPER_PORT=10300
# Config dir (downloaded model cache)
WHISPER_DATA=./data/faster-whisper
# Model size: tiny | base | small | medium | large-v3 (bigger = more accurate, more VRAM)
WHISPER_MODEL=base
# Default transcription language
WHISPER_LANG=en
