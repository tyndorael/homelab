# Core stack environment variables — copy to .env and fill in your values

# Timezone
TZ=America/Santiago

# Volume paths — absolute or relative paths on the Docker host
HOMEPAGE_CONFIG=./config/homepage

# Homepage — port exposed on the host (change if 3001 is already taken)
HOMEPAGE_PORT=3001

# Homepage — comma-separated list of hostnames/IPs allowed to access the dashboard
# Add your Ubuntu host's local IP so other devices on the LAN can reach it
# e.g. localhost,192.168.1.100
HOMEPAGE_ALLOWED_HOSTS=localhost,localhost:3001,127.0.0.1,192.168.50.x:3001

# Homepage service widget credentials (referenced in config/homepage/services.yaml)
HOMEPAGE_VAR_NAVIDROME_URL=http://navidrome.example.com  # Public URL from Nginx Proxy Manager
HOMEPAGE_VAR_PLEX_URL=http://plex.example.com/web        # Public URL from Nginx Proxy Manager
HOMEPAGE_VAR_JELLYFIN_URL=http://jellyfin.example.com    # Public URL from Nginx Proxy Manager
HOMEPAGE_VAR_PLEX_TOKEN=                      # https://support.plex.tv/articles/204059436
HOMEPAGE_VAR_JELLYFIN_API_KEY=                # Jellyfin → Dashboard → API keys
HOMEPAGE_VAR_NAVIDROME_USER=                  # Navidrome admin username
HOMEPAGE_VAR_NAVIDROME_TOKEN=                 # MD5 hash of password+salt
HOMEPAGE_VAR_NAVIDROME_SALT=                  # Random string used to generate the token
HOMEPAGE_VAR_PORTAINER_URL=http://portainer.example.com  # Public URL from Nginx Proxy Manager (or http://host-ip:9000)
HOMEPAGE_VAR_NPM_URL=http://npm.example.com              # NPM admin UI URL (or http://host-ip:81)
HOMEPAGE_VAR_NPM_EMAIL=                                  # NPM admin email
HOMEPAGE_VAR_NPM_PASSWORD=                               # NPM admin password
HOMEPAGE_VAR_QBITTORRENT_URL=http://qbittorrent.example.com  # Public URL from Nginx Proxy Manager (or http://host-ip:8080)
HOMEPAGE_VAR_QBITTORRENT_USERNAME=admin          # qBittorrent web UI username
HOMEPAGE_VAR_QBITTORRENT_PASSWORD=               # qBittorrent web UI password
