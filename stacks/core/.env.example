# Core stack environment variables — copy to .env and fill in your values

# Timezone
TZ=America/Santiago

# DuckDNS — https://www.duckdns.org
DUCKDNS_SUBDOMAINS=your-subdomain        # e.g. myhomelab (without .duckdns.org)
DUCKDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Volume paths — absolute or relative paths on the Docker host
PORTAINER_DATA=./data/portainer
NPM_DATA=./data/npm/data
NPM_LETSENCRYPT=./data/npm/letsencrypt
DUCKDNS_CONFIG=./data/duckdns/config
