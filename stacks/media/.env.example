# Media stack environment variables — copy to .env and fill in your values

# Timezone
TZ=America/Santiago

# UID/GID — run `id` on the Mac to find your values
PUID=1000
PGID=1000

# Plex claim token — get one at https://www.plex.tv/claim (expires in 4 minutes)
# Only needed on first run; leave empty after Plex is claimed
PLEX_CLAIM=

# Path on the Mac host where TrueNAS media is NFS-mounted
# e.g. /Volumes/media  — this whole tree is mounted read-only into both Plex and Jellyfin
TRUENAS_MEDIA_PATH=/Volumes/media
