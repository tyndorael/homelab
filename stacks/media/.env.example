# Media stack environment variables — copy to .env and fill in your values

# Timezone
TZ=America/Santiago

# UID/GID — run `id` to find your values
PUID=1000
PGID=1000

# Plex claim token — get one at https://www.plex.tv/claim (expires in 4 minutes)
# Only needed on first run; leave empty after Plex is claimed
PLEX_CLAIM=

# Path on the Ubuntu host where TrueNAS media is NFS-mounted
# e.g. /mnt/media  — this whole tree is mounted read-only into both Plex and Jellyfin
TRUENAS_MEDIA_PATH=/mnt/media

# Volume paths — absolute or relative paths on the Docker host
PLEX_CONFIG=./config/plex
JELLYFIN_CONFIG=./config/jellyfin
JELLYFIN_CACHE=./cache/jellyfin
NAVIDROME_DATA=./data/navidrome

# Path on the Ubuntu host where TrueNAS music library is NFS-mounted
TRUENAS_MUSIC_PATH=/mnt/music

# qBittorrent — writable path for completed/incomplete downloads
DOWNLOADS_PATH=/mnt/downloads
QBITTORRENT_CONFIG=./config/qbittorrent

# Bazarr — subtitle automation config dir.
# Note: Bazarr mounts TRUENAS_MEDIA_PATH read-write to drop subtitles next to videos.
BAZARR_CONFIG=./config/bazarr

# Tautulli — Plex usage analytics config dir
TAUTULLI_CONFIG=./config/tautulli
