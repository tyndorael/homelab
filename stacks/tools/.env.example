# Tools stack environment variables — copy to .env and fill in your values

# Timezone
TZ=America/Santiago

# UID/GID — run `id` to find your values
PUID=1000
PGID=1000

# Speedtest Tracker — required Laravel app key (encrypts stored data)
# Generate one with:  echo -n 'base64:'; openssl rand -base64 32
# Paste the full value, including the leading "base64:" prefix
SPEEDTEST_APP_KEY=

# Speedtest Tracker — must match how you reach the UI (host IP + host port, or NPM public URL)
SPEEDTEST_APP_URL=http://192.168.50.x:8765

# Speedtest Tracker — cron schedule for automated tests (default: every 6 hours)
SPEEDTEST_SCHEDULE=0 */6 * * *

# Speedtest Tracker — comma-separated Ookla server IDs (leave empty to auto-select)
# List available servers with:
#   docker run --rm --entrypoint /bin/bash lscr.io/linuxserver/speedtest-tracker:latest list-servers
SPEEDTEST_SERVERS=

# Speedtest Tracker — port exposed on the host (change if 8765 is already taken)
SPEEDTEST_PORT=8765

# Volume path — config and SQLite database (absolute or relative to this stack dir)
SPEEDTEST_CONFIG=./config/speedtest
